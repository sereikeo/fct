# Backend
NOTION_TOKEN=
NOTION_DATABASE_ID=
FCT_OPENING_BALANCE=0
FCT_OPENING_BALANCE_PERSONAL=
FCT_OPENING_BALANCE_MAPLE=
# ISO-8601 date (YYYY-MM-DD). Seed balance is valid at this date.
# Budget items with due_date < this are treated as overdue and surfaced
# separately (not deducted from the forward projection).
FCT_OPENING_BALANCE_DATE=
SYNC_INTERVAL_MS=300000
CC_STMT_DUE_DAY=25
CC_STMT_CLOSE_DAY=12
LOW_BALANCE_ALERT=3500
PORT=3001
NODE_ENV=development

# SQLite — override to point at NAS volume in production
SQLITE_DIR=./data

# Docker / CI
GITHUB_REPOSITORY_OWNER=
GITHUB_REPO_URL=
GH_PAT=
