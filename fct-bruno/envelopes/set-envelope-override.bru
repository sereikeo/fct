meta {
  name: Set Envelope Override
  type: http
  seq: 2
}

// id = budget_item id from GET /api/envelopes
// period = YYYY-MM (the month the override applies to)

put {
  url: {{base_url}}/api/envelopes/:id/override
  body: json
  auth: none
}

params:path {
  id: REPLACE_WITH_BUDGET_ITEM_ID
}

body:json {
  {
    "period": "2026-04",
    "overrideAmount": 250.00
  }
}
