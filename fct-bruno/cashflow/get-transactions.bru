meta {
  name: Get Drift Report
  type: http
  seq: 2
}

// Returns confirmed transactions where the snapshotted amount has diverged
// from the current Notion forecast, sorted by largest gap first.
// Use PATCH /api/drift/:notionPageId to apply a correction.

get {
  url: {{base_url}}/api/drift
  body: none
  auth: none
}
